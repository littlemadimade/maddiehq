# ── Remote dev (phone QA via Tailscale) ────────────────────────────────
# Caddy + Tailscale sidecar joins the tailnet as ${TS_HOSTNAME} and serves
# Next dev over real HTTPS at https://${TS_HOSTNAME}.<tailnet>.ts.net.
# See README → "Remote Dev" for the iOS Safari gotcha (HSTS-preloaded
# *.ts.net requires HTTPS, plain HTTP is rejected).

# Get a fresh ephemeral auth key from:
#   https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# Hostname the sidecar registers on the tailnet (no spaces, no dots).
# Final URL: https://<TS_HOSTNAME>.<your-tailnet>.ts.net
TS_HOSTNAME=maddiehq

# Localhost port the sidecar publishes (it owns this binding;
# the Next container shares its netns and listens internally on 3000).
DEV_PORT=3005

# Public-facing URL of the dev server. Set to the tailnet URL so emails
# (verification, password reset) link back to the externally-reachable
# domain, not localhost.
APP_URL=https://maddiehq.gate-cardassian.ts.net
