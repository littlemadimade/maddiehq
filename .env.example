# ── Instagram ─────────────────────────────────────────────────────────
# Create a Meta App at https://developers.facebook.com/apps/
# App type: Business
# Add "Instagram Graph API" product
#
# INSTAGRAM_APP_ID and INSTAGRAM_APP_SECRET come from your Meta App's
# Settings > Basic page.
#
# INSTAGRAM_INITIAL_TOKEN is a short-lived token generated once via the
# Graph API Explorer (https://developers.facebook.com/tools/explorer/).
# Select your app, request permissions: instagram_basic, instagram_manage_insights, pages_show_list
# Generate the token, paste it here, then run the token exchange endpoint.
# After exchange, the app stores a long-lived token in the database and
# refreshes it automatically. You can remove this value after first use.

INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_INITIAL_TOKEN=

# ── Reddit ────────────────────────────────────────────────────────────
# Create a "script" type app at https://www.reddit.com/prefs/apps
# The redirect URI can be http://localhost:3000 (not used for script apps)

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
