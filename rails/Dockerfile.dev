# Development Dockerfile for Rails
# Designed for use with docker-compose volume mounts for hot reload

FROM ruby:3.3-alpine

RUN apk add --no-cache \
    build-base \
    git \
    sqlite-dev \
    postgresql-dev \
    yaml-dev \
    tzdata \
    curl

WORKDIR /app

# Install gems — force native compilation on Alpine (musl)
COPY Gemfile Gemfile.lock ./
RUN bundle config set --local force_ruby_platform true && \
    bundle install

# Copy application code (will be overridden by volume mount in compose)
COPY . .

ENV RAILS_ENV=development \
    RAILS_LOG_TO_STDOUT=1

EXPOSE 3014

CMD ["sh", "-c", "bin/rails db:prepare && bin/rails server -b 0.0.0.0 -p 3014"]
