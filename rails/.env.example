# Auth
SECRET_KEY_BASE=change-me-run-openssl-rand-hex-64
APP_URL=http://localhost:3014
APP_NAME=AppSeed

# PostgreSQL — set DATABASE_URL to use PG instead of SQLite
# DATABASE_URL=postgres://user:password@localhost:5432/appseed

# Waitlist mode — set to "true" to gate signups behind invite codes
# WAITLIST_MODE=true

# OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# Email
# RESEND_API_KEY=re_...

# Stripe
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Analytics — pluggable event tracking (posthog, plausible, console, none)
# ANALYTICS_PROVIDER=posthog
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://app.posthog.com
# PLAUSIBLE_DOMAIN=yourapp.com
# PLAUSIBLE_HOST=https://plausible.io

# AI Chatbot — Anthropic Claude (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...
# CHAT_MODEL=claude-sonnet-4-20250514
# CHAT_MAX_TOKENS=1024

# Voice — ElevenLabs TTS (https://elevenlabs.io — optional)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9

# Error monitoring — Sentry (https://sentry.io — free tier: 5K errors/month)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Admin
ADMIN_EMAILS=admin@example.com
