<div id="<%= id %>"
     data-controller="modal"
     data-modal-open-value="<%= open %>"
     data-action="keydown->modal#handleKeydown click->modal#handleBackdropClick">
  <div class="<%= backdrop_classes %>"
       data-modal-target="backdrop"
       aria-hidden="<%= !open %>">
    <div role="dialog"
         aria-modal="true"
         aria-labelledby="<%= title_id %>"
         tabindex="-1"
         data-modal-target="panel"
         class="<%= panel_classes %>">
      <div class="flex items-start justify-between px-5 py-4 border-b border-border">
        <h2 id="<%= title_id %>" class="text-base font-semibold text-foreground"><%= title %></h2>
        <button type="button"
                aria-label="Close dialog"
                data-action="click->modal#close"
                class="rounded-lg p-1 -m-1 text-muted-foreground hover:text-foreground hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div class="p-5">
        <%= content %>
      </div>
    </div>
  </div>
</div>
