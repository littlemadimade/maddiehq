<div role="alert" aria-live="<%= aria_live %>" class="<%= classes %>">
  <div class="flex-1 min-w-0">
    <% if title.present? %>
      <p class="font-semibold mb-1"><%= title %></p>
    <% end %>
    <div><%= content %></div>
  </div>
  <% if dismissible %>
    <button type="button"
            aria-label="Dismiss"
            data-action="click->parent#dismiss"
            class="flex-shrink-0 rounded-lg p-1 -m-1 hover:bg-black/5 dark:hover:bg-white/5">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  <% end %>
</div>
