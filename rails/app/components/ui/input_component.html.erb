<div class="space-y-1">
  <% if label.present? %>
    <label for="<%= id %>" class="block text-xs font-medium text-foreground">
      <%= label %><% if required %><span class="text-destructive ml-0.5" aria-hidden="true">*</span><% end %>
    </label>
  <% end %>

  <%= tag.input(
        type: type,
        name: name,
        id: id,
        value: value,
        placeholder: placeholder,
        required: required,
        autocomplete: autocomplete,
        class: input_classes,
        "aria-invalid": error.present? ? "true" : nil,
        "aria-describedby": described_by,
        "aria-required": required ? "true" : nil,
        **html_opts
      ) %>

  <% if error.present? %>
    <p id="<%= id %>-error" class="text-xs text-destructive"><%= error %></p>
  <% elsif helper.present? %>
    <p id="<%= id %>-helper" class="text-xs text-muted-foreground"><%= helper %></p>
  <% end %>
</div>
