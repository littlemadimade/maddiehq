<% content_for(:title) { "Sign In" } %>

<%
  # Tab classes captured once so the paired <button> markup below isn't a wall
  # of Tailwind. Each tab button still carries its own data-controller metadata
  # so the tabs_controller.js a11y pass still works.
  tab_btn = "flex-1 text-sm font-medium py-2 px-3 rounded-md transition-colors text-muted-foreground hover:text-foreground"
  tab_active = "bg-background text-foreground shadow-sm"

  social_btn = "flex items-center justify-center gap-2 border border-input rounded-lg py-2.5 px-3 text-sm font-medium text-foreground hover:bg-muted transition-colors"
%>

<div class="min-h-screen bg-muted flex flex-col items-center justify-center px-4"
     data-controller="auth-form tabs"
     data-tabs-default-value="login"
     data-auth-form-waitlist-mode-value="<%= ENV.fetch('WAITLIST_MODE', 'false') %>">
  <!-- Logo -->
  <div class="flex items-center justify-center mb-8">
    <span class="text-2xl font-bold text-foreground"><%= app_name %></span>
  </div>

  <!-- Main card -->
  <div class="w-full max-w-sm">
    <%= render UI::CardComponent.new do %>
      <!-- Tabs -->
      <div class="flex bg-muted rounded-lg p-1 mb-6">
        <button type="button"
                data-tabs-target="tab"
                data-action="click->tabs#switch keydown->tabs#handleKeydown"
                data-tab="login"
                data-active-class="<%= tab_active %>"
                class="<%= tab_btn %>">Sign In</button>
        <button type="button"
                data-tabs-target="tab"
                data-action="click->tabs#switch keydown->tabs#handleKeydown"
                data-tab="signup"
                data-active-class="<%= tab_active %>"
                class="<%= tab_btn %>">Sign Up</button>
      </div>

      <!-- Social sign-in buttons (2-col grid, Microsoft spans full width) -->
      <div class="grid grid-cols-2 gap-2 mb-6">
        <button type="button" data-action="click->auth-form#socialSignIn" data-provider="google" class="<%= social_btn %>">
          <svg class="w-4 h-4 shrink-0" aria-hidden="true" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          <span>Google</span>
        </button>
        <button type="button" data-action="click->auth-form#socialSignIn" data-provider="apple" class="<%= social_btn %>">
          <svg class="w-4 h-4 shrink-0" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span>Apple</span>
        </button>
        <button type="button" data-action="click->auth-form#socialSignIn" data-provider="github" class="<%= social_btn %>">
          <svg class="w-4 h-4 shrink-0" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span>GitHub</span>
        </button>
        <button type="button" data-action="click->auth-form#socialSignIn" data-provider="facebook" class="<%= social_btn %>">
          <svg class="w-4 h-4 shrink-0" aria-hidden="true" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          <span>Facebook</span>
        </button>
        <button type="button" data-action="click->auth-form#socialSignIn" data-provider="microsoft" class="col-span-2 <%= social_btn %>">
          <svg class="w-4 h-4 shrink-0" aria-hidden="true" viewBox="0 0 24 24" fill="none"><path d="M0 0h11.377v11.372H0z" fill="#F25022"/><path d="M12.623 0H24v11.372H12.623z" fill="#7FBA00"/><path d="M0 12.628h11.377V24H0z" fill="#00A4EF"/><path d="M12.623 12.628H24v11.372H12.623z" fill="#FFB900"/></svg>
          <span>Microsoft</span>
        </button>
      </div>

      <!-- Divider -->
      <div class="relative mb-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-border"></div>
        </div>
        <div class="relative flex justify-center text-xs">
          <span class="px-2 bg-card text-muted-foreground">Or continue with email</span>
        </div>
      </div>

      <!-- Error display -->
      <div data-auth-form-target="error" class="hidden mb-4">
        <%= render UI::AlertComponent.new(variant: :error) do %>
          <span data-auth-form-target="errorText"></span>
        <% end %>
      </div>

      <!-- Login form -->
      <form data-auth-form-target="loginForm" data-tabs-target="panel" data-panel="login" data-action="submit->auth-form#handleLogin" class="space-y-4">
        <%= render UI::InputComponent.new(
              name: "email",
              label: "Email",
              type: "email",
              required: true,
              autocomplete: "email",
              placeholder: "you@example.com"
            ) %>
        <%= render UI::InputComponent.new(
              name: "password",
              label: "Password",
              type: "password",
              required: true,
              autocomplete: "current-password",
              placeholder: "Your password"
            ) %>
        <div class="text-right">
          <a href="/forgot-password" class="text-xs text-primary hover:text-primary/90">Forgot password?</a>
        </div>
        <%= render UI::ButtonComponent.new(
              type: "submit",
              variant: :primary,
              class: "w-full",
              data: { "auth-form-target": "loginButton" }
            ) { "Sign In" } %>
      </form>

      <!-- Signup form -->
      <form data-auth-form-target="signupForm" data-tabs-target="panel" data-panel="signup" data-action="submit->auth-form#handleSignup" class="space-y-4 hidden">
        <%= render UI::InputComponent.new(
              name: "email",
              label: "Email",
              type: "email",
              required: true,
              autocomplete: "email",
              placeholder: "you@example.com"
            ) %>
        <%= render UI::InputComponent.new(
              name: "password",
              label: "Password",
              type: "password",
              required: true,
              autocomplete: "new-password",
              placeholder: "At least 8 characters"
            ) %>
        <%= render UI::InputComponent.new(
              name: "password_confirmation",
              label: "Confirm Password",
              type: "password",
              required: true,
              autocomplete: "new-password",
              placeholder: "Repeat your password"
            ) %>
        <!-- Invite code (only shown in waitlist mode) -->
        <div data-auth-form-target="inviteCodeField" class="hidden">
          <%= render UI::InputComponent.new(
                name: "invite_code",
                label: "Invite Code",
                type: "text",
                placeholder: "Enter your invite code",
                data: { "auth-form-target": "inviteCodeInput" }
              ) %>
        </div>
        <%= render UI::ButtonComponent.new(
              type: "submit",
              variant: :primary,
              class: "w-full",
              data: { "auth-form-target": "signupButton" }
            ) { "Create Account" } %>
      </form>
    <% end %>
  </div>

  <!-- 2FA verification (hidden by default) -->
  <div data-auth-form-target="mfaSection" class="hidden w-full max-w-sm mt-8">
    <%= render UI::CardComponent.new(title: "Two-Factor Authentication", subtitle: "Enter the 6-digit code from your authenticator app.") do %>
      <input type="text"
             data-auth-form-target="mfaInput"
             placeholder="000000"
             maxlength="6"
             inputmode="numeric"
             aria-label="Authenticator code"
             class="w-full border border-input bg-background rounded-lg px-3 py-3 text-sm text-foreground text-center text-xl tracking-widest font-mono focus:outline-none focus:ring-2 focus:ring-ring mb-4" />

      <%= render UI::ButtonComponent.new(
            variant: :primary,
            class: "w-full",
            data: { "auth-form-target": "mfaButton", action: "click->auth-form#verifyMfa" }
          ) { "Verify" } %>

      <button type="button"
              data-action="click->auth-form#cancelMfa"
              class="w-full mt-3 text-sm text-muted-foreground hover:text-foreground">
        Back to login
      </button>
    <% end %>
  </div>
</div>
