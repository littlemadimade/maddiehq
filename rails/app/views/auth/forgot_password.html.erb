<% content_for(:title) { "Forgot Password" } %>

<div class="min-h-screen bg-muted flex flex-col items-center justify-center px-4">
  <div class="flex items-center justify-center mb-8">
    <span class="text-2xl font-bold text-foreground"><%= app_name %></span>
  </div>

  <div class="w-full max-w-sm" data-controller="auth-form">
    <%= render UI::CardComponent.new(title: "Reset your password", subtitle: "Enter your email and we'll send you a reset link.") do %>
      <div data-auth-form-target="error" class="hidden mb-4">
        <%= render UI::AlertComponent.new(variant: :error) do %>
          <span data-auth-form-target="errorText"></span>
        <% end %>
      </div>

      <div data-auth-form-target="successMessage" class="hidden mb-4">
        <%= render UI::AlertComponent.new(variant: :success) do %>
          <span data-auth-form-target="successText"></span>
        <% end %>
      </div>

      <form data-action="submit->auth-form#handleForgotPassword" class="space-y-4">
        <%= render UI::InputComponent.new(
              name: "email",
              label: "Email",
              type: "email",
              required: true,
              autocomplete: "email",
              placeholder: "you@example.com"
            ) %>

        <%= render UI::ButtonComponent.new(
              type: "submit",
              variant: :primary,
              class: "w-full",
              data: { "auth-form-target": "submitButton" }
            ) { "Send Reset Link" } %>
      </form>

      <div class="mt-4 text-center">
        <a href="/auth" class="text-sm text-muted-foreground hover:text-foreground">Back to sign in</a>
      </div>
    <% end %>
  </div>
</div>
