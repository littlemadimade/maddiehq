<% content_for(:title) { "Verify Email" } %>

<div class="min-h-screen bg-muted flex flex-col items-center justify-center px-4" data-controller="auth-form" data-auth-form-auto-verify-value="true">
  <div class="flex items-center justify-center mb-8">
    <span class="text-2xl font-bold text-foreground"><%= app_name %></span>
  </div>

  <div class="w-full max-w-sm">
    <%= render UI::CardComponent.new do %>
      <div class="text-center">
        <!-- Pending state -->
        <div data-auth-form-target="verifyPending">
          <div class="w-12 h-12 rounded-full bg-accent flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </div>
          <h2 class="text-lg font-bold text-foreground mb-2">Verifying your email...</h2>
          <p class="text-sm text-muted-foreground">Please wait while we verify your email address.</p>
        </div>

        <!-- Success state -->
        <div data-auth-form-target="verifySuccess" class="hidden">
          <div class="w-12 h-12 rounded-full bg-success/15 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h2 class="text-lg font-bold text-foreground mb-2">Email verified!</h2>
          <p class="text-sm text-muted-foreground mb-4">Your email has been verified successfully.</p>
          <%= render UI::ButtonComponent.new(as: :link, href: "/app", variant: :primary) { "Go to Dashboard" } %>
        </div>

        <!-- Error state -->
        <div data-auth-form-target="verifyError" class="hidden">
          <div class="w-12 h-12 rounded-full bg-destructive/15 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-destructive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </div>
          <h2 class="text-lg font-bold text-foreground mb-2">Verification failed</h2>
          <p class="text-sm text-muted-foreground mb-4" data-auth-form-target="verifyErrorMessage">The verification link may have expired or is invalid.</p>
          <%= render UI::ButtonComponent.new(as: :link, href: "/auth", variant: :primary) { "Back to Sign In" } %>
        </div>
      </div>
    <% end %>
  </div>
</div>
