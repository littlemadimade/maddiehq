<% content_for(:title) { "Roles & Permissions" } %>

<%
  permissions = %w[
    items:create items:read items:update items:delete
    admin:users admin:roles admin:settings admin:waitlist
    admin:logs admin:analytics admin:crm admin:database
  ]
%>

<div data-controller="admin-roles">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-foreground">Roles & Permissions</h1>
    <%= render UI::ButtonComponent.new(variant: :primary, size: :sm, data: { action: "click->admin-roles#showCreateForm" }) { "Create Role" } %>
  </div>

  <!-- Create/Edit form (hidden by default) -->
  <div data-admin-roles-target="form" class="hidden mb-6">
    <%= render UI::CardComponent.new do %>
      <h3 data-admin-roles-target="formTitle" class="text-sm font-semibold text-foreground mb-4">Create Role</h3>
      <input type="hidden" data-admin-roles-target="editId" />
      <div class="space-y-4">
        <%= render UI::InputComponent.new(
              name: "role_name",
              label: "Name",
              type: "text",
              placeholder: "e.g. editor, moderator",
              data: { "admin-roles-target": "nameInput" }
            ) %>
        <%= render UI::InputComponent.new(
              name: "role_description",
              label: "Description",
              type: "text",
              placeholder: "Optional description",
              data: { "admin-roles-target": "descInput" }
            ) %>
        <div>
          <label class="block text-xs font-medium text-muted-foreground mb-2">Permissions</label>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
            <% permissions.each do |perm| %>
              <label class="flex items-center gap-2 text-sm text-foreground">
                <input type="checkbox" value="<%= perm %>" data-admin-roles-target="perm" class="rounded border-input" />
                <%= perm %>
              </label>
            <% end %>
          </div>
        </div>
        <div class="flex gap-2">
          <%= render UI::ButtonComponent.new(variant: :primary, data: { action: "click->admin-roles#saveRole" }) { "Save" } %>
          <%= render UI::ButtonComponent.new(variant: :secondary, data: { action: "click->admin-roles#hideForm" }) { "Cancel" } %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Roles list -->
  <div data-admin-roles-target="list" class="space-y-3">
    <p class="text-sm text-muted-foreground text-center py-8">Loading roles...</p>
  </div>
</div>
