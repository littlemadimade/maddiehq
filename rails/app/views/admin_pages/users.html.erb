<% content_for(:title) { "Users" } %>

<div data-controller="admin-users">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-foreground">Users</h1>
    <div class="flex items-center gap-2">
      <input type="text" placeholder="Search users..." aria-label="Search users" data-admin-users-target="search" data-action="input->admin-users#search" class="border border-input bg-background text-foreground rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring" />
    </div>
  </div>

  <div class="bg-card text-card-foreground border border-border rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-muted/60 border-b border-border">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-medium text-muted-foreground uppercase">User</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-muted-foreground uppercase">Plan</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-muted-foreground uppercase">Status</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-muted-foreground uppercase">Joined</th>
          <th class="text-right px-4 py-3 text-xs font-medium text-muted-foreground uppercase">Actions</th>
        </tr>
      </thead>
      <tbody data-admin-users-target="userList" class="divide-y divide-border">
        <tr><td colspan="5" class="px-4 py-8 text-center text-muted-foreground">Loading users...</td></tr>
      </tbody>
    </table>
  </div>
</div>
