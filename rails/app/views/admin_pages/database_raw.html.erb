<% content_for(:title) { "Raw SQL" } %>

<div data-controller="admin-database">
  <div class="flex items-center gap-3 mb-6">
    <a href="/admin/database" class="text-muted-foreground hover:text-foreground" aria-label="Back to database browser">
      <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <h1 class="text-2xl font-bold text-foreground">Raw SQL</h1>
  </div>

  <%= render UI::CardComponent.new(class: "mb-4") do %>
    <textarea data-admin-database-target="sqlInput" rows="4" placeholder="SELECT * FROM users LIMIT 10;" aria-label="SQL query" class="w-full border border-input bg-background text-foreground rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-ring mb-3"></textarea>
    <%= render UI::ButtonComponent.new(variant: :primary, data: { action: "click->admin-database#runQuery" }) do %>
      <span class="inline-flex items-center gap-1.5">
        <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Run Query
      </span>
    <% end %>
  <% end %>

  <div class="bg-card text-card-foreground border border-border rounded-xl overflow-x-auto">
    <div data-admin-database-target="queryResult" class="p-8 text-center text-muted-foreground text-sm">
      Enter a query and click Run.
    </div>
  </div>
</div>
