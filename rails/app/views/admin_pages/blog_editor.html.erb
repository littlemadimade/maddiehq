<% content_for(:title) { "Blog Editor" } %>

<div data-controller="admin-blog-editor">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <a href="/admin/crm" class="text-muted-foreground hover:text-foreground" aria-label="Back to CRM">
        <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </a>
      <h1 class="text-2xl font-bold text-foreground">Blog Editor</h1>
    </div>
    <%= render UI::ButtonComponent.new(variant: :primary, size: :sm, data: { action: "click->admin-blog-editor#newPost" }) do %>
      <span class="inline-flex items-center gap-1.5">
        <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Post
      </span>
    <% end %>
  </div>

  <!-- Editor form (hidden by default) -->
  <div data-admin-blog-editor-target="editorSection" class="hidden mb-8">
    <%= render UI::CardComponent.new do %>
      <input type="hidden" data-admin-blog-editor-target="editId" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <%= render UI::InputComponent.new(
              name: "post_title",
              label: "Title",
              type: "text",
              placeholder: "Post title",
              data: { "admin-blog-editor-target": "editTitle" }
            ) %>
        <%= render UI::InputComponent.new(
              name: "post_slug",
              label: "Slug",
              type: "text",
              placeholder: "post-slug",
              data: { "admin-blog-editor-target": "editSlug" }
            ) %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div class="space-y-1">
          <label class="block text-xs font-medium text-foreground" for="blog-editor-status">Status</label>
          <select id="blog-editor-status" data-admin-blog-editor-target="editStatus" class="w-full border border-input bg-background text-foreground rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
            <option value="draft">Draft</option>
            <option value="published">Published</option>
            <option value="archived">Archived</option>
          </select>
        </div>
        <%= render UI::InputComponent.new(
              name: "post_tags",
              label: "Tags (comma-separated)",
              type: "text",
              placeholder: "rails, saas, tutorial",
              data: { "admin-blog-editor-target": "editTags" }
            ) %>
      </div>

      <div class="mb-4">
        <label class="block text-xs font-medium text-foreground mb-1" for="blog-editor-content">Content (Markdown)</label>
        <textarea data-admin-blog-editor-target="editContent" id="blog-editor-content" rows="16" placeholder="Write your post in Markdown..." class="w-full border border-input bg-background text-foreground rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-ring"></textarea>
      </div>

      <div class="flex items-center justify-between">
        <%= render UI::ButtonComponent.new(variant: :secondary, data: { action: "click->admin-blog-editor#cancelEdit" }) { "Cancel" } %>
        <%= render UI::ButtonComponent.new(variant: :primary, data: { action: "click->admin-blog-editor#savePost", "admin-blog-editor-target": "saveButton" }) { "Save Post" } %>
      </div>
    <% end %>
  </div>

  <!-- Posts list -->
  <div data-admin-blog-editor-target="listSection" class="bg-card text-card-foreground border border-border rounded-xl">
    <div data-admin-blog-editor-target="postList" class="divide-y divide-border">
      <div class="px-4 py-8 text-center text-muted-foreground text-sm">Loading posts...</div>
    </div>
  </div>
</div>
