<% content_for(:title) { "Dashboard" } %>

<div data-controller="admin-dashboard">
  <h1 class="text-2xl font-bold text-foreground mb-6">Dashboard</h1>

  <!-- Stats cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <%
      stats = [
        ["Total Users", "totalUsers"],
        ["Pro Users", "proUsers"],
        ["New Today", "newToday"],
        ["Revenue (MRR)", "revenue"],
      ]
    %>
    <% stats.each do |label, target| %>
      <div class="bg-card text-card-foreground border border-border rounded-xl p-5">
        <p class="text-xs text-muted-foreground mb-1"><%= label %></p>
        <p class="text-2xl font-bold text-foreground" data-admin-dashboard-target="<%= target %>">--</p>
      </div>
    <% end %>
  </div>

  <!-- Recent activity -->
  <%= render UI::CardComponent.new(title: "Recent Activity") do %>
    <div data-admin-dashboard-target="activity">
      <p class="text-sm text-muted-foreground text-center py-8">Loading activity...</p>
    </div>
  <% end %>
</div>
