<% content_for(:title) { "User Detail" } %>

<div data-controller="admin-user-detail">
  <div class="flex items-center gap-3 mb-6">
    <a href="/admin/users" class="text-muted-foreground hover:text-foreground" aria-label="Back to users">
      <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <h1 class="text-2xl font-bold text-foreground">User Detail</h1>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
      <%= render UI::CardComponent.new do %>
        <div class="space-y-4" data-admin-user-detail-target="info">
          <p class="text-sm text-muted-foreground text-center py-4">Loading user details...</p>
        </div>
      <% end %>
    </div>

    <%= render UI::CardComponent.new(title: "Actions") do %>
      <div class="space-y-2" data-admin-user-detail-target="actions">
        <p class="text-sm text-muted-foreground">Loading...</p>
      </div>
    <% end %>
  </div>
</div>
