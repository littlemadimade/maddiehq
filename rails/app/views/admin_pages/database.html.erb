<% content_for(:title) { "Database" } %>

<div data-controller="admin-database">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-foreground">Database Browser</h1>
    <%= render UI::ButtonComponent.new(as: :link, href: "/admin/database/raw", variant: :outline, size: :sm) do %>
      <span class="inline-flex items-center gap-1.5">
        <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        Raw SQL
      </span>
    <% end %>
  </div>

  <!-- Table selector -->
  <div class="mb-4 flex items-center gap-2">
    <label class="text-sm text-muted-foreground" for="admin-database-table">Table:</label>
    <select id="admin-database-table" data-admin-database-target="tableSelect" data-action="change->admin-database#loadTable" class="border border-input bg-background text-foreground rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
      <option value="">Select a table...</option>
    </select>
  </div>

  <!-- Table data -->
  <div class="bg-card text-card-foreground border border-border rounded-xl overflow-x-auto">
    <div data-admin-database-target="tableData" class="p-8 text-center text-muted-foreground text-sm">
      Select a table to view its contents.
    </div>
  </div>
</div>
