<% content_for(:title) { "CRM" } %>

<div data-controller="admin-crm">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-foreground">CRM</h1>
    <%= render UI::ButtonComponent.new(as: :link, href: "/admin/crm/blog", variant: :primary, size: :sm) do %>
      <span class="inline-flex items-center gap-1.5">
        <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Blog Editor
      </span>
    <% end %>
  </div>

  <!-- Newsletter subscribers -->
  <%= render UI::CardComponent.new(title: "Newsletter Subscribers") do %>
    <div class="overflow-x-auto -mx-5 -my-5">
      <table class="w-full text-sm">
        <thead class="bg-muted/60 border-b border-border">
          <tr>
            <th class="text-left px-4 py-3 text-xs font-medium text-muted-foreground uppercase">Email</th>
            <th class="text-left px-4 py-3 text-xs font-medium text-muted-foreground uppercase">Subscribed</th>
            <th class="text-right px-4 py-3 text-xs font-medium text-muted-foreground uppercase">Actions</th>
          </tr>
        </thead>
        <tbody data-admin-crm-target="subscriberList" class="divide-y divide-border">
          <tr><td colspan="3" class="px-4 py-8 text-center text-muted-foreground">Loading subscribers...</td></tr>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
