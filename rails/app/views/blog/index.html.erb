<% content_for(:title) { "Blog" } %>
<% content_for(:description) { "Guides, tutorials, and updates from the #{app_name} team." } %>

<div class="min-h-screen bg-background">
  <!-- Header -->
  <header class="border-b border-border bg-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 group">
        <svg class="w-5 h-5 text-primary group-hover:scale-110 transition-transform" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2C12 2 8 6 8 10C8 12.21 9.79 14 12 14C14.21 14 16 12.21 16 10C16 6 12 2 12 2Z"/><path d="M12 14V22"/><path d="M8 18H16"/></svg>
        <span class="font-bold text-foreground"><%= app_name %></span>
      </a>
      <nav class="flex items-center gap-4 text-sm">
        <a href="/blog" class="font-medium text-primary">Blog</a>
        <a href="/changelog" class="text-muted-foreground hover:text-foreground transition-colors">Changelog</a>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold text-foreground tracking-tight mb-4">Blog</h1>
      <p class="text-lg text-muted-foreground max-w-lg mx-auto">Guides, tutorials, and updates from the <%= app_name %> team.</p>
    </div>
  </section>

  <!-- Tag filters -->
  <% if @posts.present? %>
    <% all_tags = @posts.flat_map(&:tags_list).uniq.sort %>
    <% if all_tags.any? %>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 mb-8">
        <div class="flex flex-wrap gap-2">
          <%
            active_tag_class = "bg-accent text-accent-foreground"
            inactive_tag_class = "bg-muted text-muted-foreground hover:bg-muted/80"
          %>
          <a href="/blog" class="px-3 py-1 text-sm rounded-full transition-colors <%= @tag.blank? ? active_tag_class : inactive_tag_class %>">All</a>
          <% all_tags.each do |tag| %>
            <a href="/blog?tag=<%= tag %>" class="px-3 py-1 text-sm rounded-full transition-colors <%= @tag == tag ? active_tag_class : inactive_tag_class %>"><%= tag %></a>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- Posts -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <% if @posts.blank? %>
        <div class="text-center py-20">
          <p class="text-muted-foreground">No posts yet. Check back soon!</p>
        </div>
      <% else %>
        <div class="space-y-8">
          <% @posts.each do |post| %>
            <article class="group border border-border rounded-2xl p-6 hover:border-primary/50 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300">
              <div class="flex flex-wrap items-center gap-3 text-xs text-muted-foreground mb-3">
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  <%= post.published_at&.strftime("%B %d, %Y") %>
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <%= post.reading_time %>
                </span>
              </div>
              <a href="/blog/<%= post.slug %>" class="block">
                <h2 class="text-xl font-bold text-foreground mb-2 group-hover:text-primary transition-colors"><%= post.title %></h2>
              </a>
              <p class="text-sm text-muted-foreground leading-relaxed mb-4"><%= post.content.truncate(200) %></p>
              <% if post.tags_list.any? %>
                <div class="flex flex-wrap gap-1.5">
                  <% post.tags_list.each do |tag| %>
                    <a href="/blog?tag=<%= tag %>" class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-full bg-muted text-muted-foreground hover:bg-muted/80 transition-colors">
                      <svg class="w-3 h-3" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                      <%= tag %>
                    </a>
                  <% end %>
                </div>
              <% end %>
            </article>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>
</div>
