<% content_for(:title) { "Settings" } %>

<%
  # Section icons — local to this view so we don't need a helper module.
  # Each string is rendered inside the CardComponent header via the
  # component's `icon:` slot, which html_safe's it.
  icons = {
    account: '<svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
    palette: '<svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"/><circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"/><circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"/><circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 011.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.555C21.965 6.012 17.461 2 12 2z"/></svg>',
    card: '<svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
    shield: '<svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    bell: '<svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>',
    webhook: '<svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>',
    download: '<svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>',
  }
%>

<div class="min-h-screen bg-muted" data-controller="settings">
  <!-- Header -->
  <header class="bg-card border-b border-border sticky top-0 z-10">
    <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/app" class="flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors">
        <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        <svg class="w-5 h-5 text-primary" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2C12 2 8 6 8 10C8 12.21 9.79 14 12 14C14.21 14 16 12.21 16 10C16 6 12 2 12 2Z"/><path d="M12 14V22"/><path d="M8 18H16"/></svg>
        <span class="font-bold text-foreground"><%= app_name %></span>
      </a>
      <h1 class="text-sm font-semibold text-foreground">Settings</h1>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-6 space-y-6">

    <!-- Account -->
    <%= render UI::CardComponent.new(title: "Account", icon: icons[:account]) do %>
      <div class="space-y-4">
        <!-- Avatar -->
        <div class="flex items-center gap-4 p-3 bg-muted/60 rounded-lg" data-controller="file-upload" data-file-upload-save-url-value="/api/settings/avatar">
          <img data-file-upload-target="preview" src="" alt="Avatar" class="hidden w-12 h-12 rounded-full object-cover" />
          <div data-file-upload-target="initial" class="w-12 h-12 bg-accent text-accent-foreground rounded-full flex items-center justify-center font-bold text-lg" data-settings-target="avatarInitial">?</div>
          <div class="flex-1">
            <p class="text-sm font-medium text-foreground">Profile Photo</p>
            <p class="text-xs text-muted-foreground">Upload an avatar image</p>
          </div>
          <input type="file" accept="image/*" data-file-upload-target="input" data-action="change->file-upload#upload" class="hidden" />
          <%= render UI::ButtonComponent.new(variant: :secondary, size: :sm, data: { action: "click->file-upload#trigger" }) do %>
            <span class="inline-flex items-center gap-2">
              <svg class="w-3 h-3" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              <span data-file-upload-target="status">Upload</span>
            </span>
          <% end %>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 text-muted-foreground mt-0.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <div>
              <p class="text-xs text-muted-foreground">Email</p>
              <p class="text-sm font-medium text-foreground" data-settings-target="email">Loading...</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 text-muted-foreground mt-0.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div>
              <p class="text-xs text-muted-foreground">Auth Provider</p>
              <p class="text-sm font-medium text-foreground" data-settings-target="provider">Loading...</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 text-muted-foreground mt-0.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <div>
              <p class="text-xs text-muted-foreground">Member Since</p>
              <p class="text-sm font-medium text-foreground" data-settings-target="memberSince">Loading...</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg data-settings-target="verifiedIcon" class="w-4 h-4 text-muted-foreground mt-0.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            <div>
              <p class="text-xs text-muted-foreground">Email Verification</p>
              <p class="text-sm font-medium text-foreground" data-settings-target="verificationStatus">Loading...</p>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Appearance -->
    <%= render UI::CardComponent.new(title: "Appearance", icon: icons[:palette]) do %>
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-sm font-medium text-foreground">Theme</h3>
          <p class="text-xs text-muted-foreground mt-0.5">Choose between light, dark, or system preference.</p>
        </div>
        <div class="flex items-center gap-1 bg-muted rounded-lg p-1" data-controller="theme" role="group" aria-label="Theme">
          <button type="button" data-action="click->theme#setLight" class="p-2 rounded-md text-muted-foreground hover:text-foreground transition-colors" aria-label="Light">
            <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          </button>
          <button type="button" data-action="click->theme#setDark" class="p-2 rounded-md text-muted-foreground hover:text-foreground transition-colors" aria-label="Dark">
            <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
          </button>
          <button type="button" data-action="click->theme#setSystem" class="p-2 rounded-md text-muted-foreground hover:text-foreground transition-colors" aria-label="System">
            <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </button>
        </div>
      </div>
    <% end %>

    <!-- Subscription & Billing -->
    <%= render UI::CardComponent.new(title: "Subscription & Billing", icon: icons[:card]) do %>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-sm text-muted-foreground">Current plan</span>
          <%= render UI::BadgeComponent.new(variant: :default, data: { "settings-target": "planBadge" }) { "Free" } %>
        </div>
        <%= render UI::ButtonComponent.new(variant: :primary, data: { "settings-target": "billingButton", action: "click->settings#manageBilling" }) do %>
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" aria-hidden="true" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Upgrade to Pro
          </span>
        <% end %>
      </div>
    <% end %>

    <!-- Security (MFA) -->
    <%= render UI::CardComponent.new(title: "Security", icon: icons[:shield]) do %>
      <div class="space-y-4">
        <div class="flex items-center justify-between p-3 bg-muted/60 rounded-lg">
          <div>
            <h3 class="text-sm font-medium text-foreground">Two-Factor Authentication</h3>
            <p class="text-xs text-muted-foreground mt-0.5" data-settings-target="mfaDescription">Add an extra layer of security with TOTP codes.</p>
          </div>
          <%= render UI::BadgeComponent.new(variant: :default, data: { "settings-target": "mfaBadge" }) { "Disabled" } %>
        </div>

        <!-- MFA enable form -->
        <div data-settings-target="mfaEnableForm" class="space-y-3">
          <p class="text-sm text-muted-foreground">Enter your password to enable MFA:</p>
          <input type="password" data-settings-target="mfaPassword" placeholder="Your password" aria-label="Password" class="w-full border border-input bg-background text-foreground rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring" />
          <%= render UI::ButtonComponent.new(variant: :primary, class: "w-full", data: { action: "click->settings#enableMfa", "settings-target": "mfaEnableButton" }) { "Enable MFA" } %>
        </div>

        <!-- MFA disable form (hidden by default) -->
        <div data-settings-target="mfaDisableForm" class="hidden space-y-3">
          <p class="text-sm text-muted-foreground">Enter your password to disable MFA:</p>
          <input type="password" data-settings-target="mfaDisablePassword" placeholder="Your password" aria-label="Password" class="w-full border border-input bg-background text-foreground rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring" />
          <%= render UI::ButtonComponent.new(variant: :destructive, class: "w-full", data: { action: "click->settings#disableMfa", "settings-target": "mfaDisableButton" }) { "Disable MFA" } %>
        </div>

        <!-- MFA QR code (hidden by default) -->
        <div data-settings-target="mfaQrSection" class="hidden space-y-4">
          <h3 class="text-sm font-medium text-foreground">Scan QR Code</h3>
          <p class="text-sm text-muted-foreground">Use an authenticator app to scan this code:</p>
          <div class="flex justify-center">
            <img data-settings-target="mfaQrImage" src="" alt="MFA QR Code" class="w-48 h-48" />
          </div>
          <p data-settings-target="mfaSecret" class="hidden text-xs text-muted-foreground text-center"></p>
          <%= render UI::ButtonComponent.new(variant: :primary, class: "w-full", data: { action: "click->settings#showVerifyStep" }) { "Continue to Verification" } %>
        </div>

        <!-- MFA verify (hidden by default) -->
        <div data-settings-target="mfaVerifySection" class="hidden space-y-4">
          <h3 class="text-sm font-medium text-foreground">Verify Setup</h3>
          <p class="text-sm text-muted-foreground">Enter the 6-digit code from your authenticator app:</p>
          <input type="text" data-settings-target="mfaVerifyCode" placeholder="000000" maxlength="6" inputmode="numeric" aria-label="Authenticator code" class="w-full border border-input bg-background text-foreground rounded-lg px-3 py-2 text-center text-2xl tracking-widest font-mono focus:ring-2 focus:ring-ring focus:border-transparent" />
          <div class="flex gap-3">
            <%= render UI::ButtonComponent.new(variant: :secondary, class: "flex-1", data: { action: "click->settings#showQrStep" }) { "Back" } %>
            <%= render UI::ButtonComponent.new(variant: :primary, class: "flex-1", data: { action: "click->settings#verifyMfa", "settings-target": "mfaVerifyButton" }) { "Verify & Enable" } %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Notifications -->
    <%= render UI::CardComponent.new(title: "Notifications", icon: icons[:bell]) do %>
      <div class="flex items-center justify-between p-3 bg-muted/60 rounded-lg">
        <div>
          <h3 class="text-sm font-medium text-foreground">In-App Notifications</h3>
          <p class="text-xs text-muted-foreground mt-0.5">Receive notifications about account activity and updates.</p>
        </div>
        <div class="relative inline-flex h-6 w-11 items-center rounded-full bg-primary cursor-pointer" role="switch" aria-checked="true" aria-label="In-app notifications">
          <span class="inline-block h-4 w-4 transform rounded-full bg-primary-foreground translate-x-6"></span>
        </div>
      </div>
    <% end %>

    <!-- Webhooks -->
    <div data-controller="webhooks">
      <%= render UI::CardComponent.new(title: "Webhooks", icon: icons[:webhook]) do %>
        <form data-action="submit->webhooks#addWebhook" class="space-y-3">
          <div class="flex gap-2">
            <input type="url" data-webhooks-target="urlInput" placeholder="https://your-server.com/webhook" aria-label="Webhook URL" class="flex-1 border border-input bg-background text-foreground rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring" />
            <%= render UI::ButtonComponent.new(type: "submit", variant: :primary) { "Add" } %>
          </div>
          <input type="text" data-webhooks-target="eventsInput" placeholder="Events (comma-separated, e.g. item.created or * for all)" aria-label="Events" class="w-full border border-input bg-background text-foreground rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring" />
        </form>
        <div data-webhooks-target="list" class="space-y-2 mt-4">
          <p class="text-sm text-muted-foreground text-center py-2">No webhooks configured.</p>
        </div>
      <% end %>
    </div>

    <!-- Data & Privacy -->
    <%= render UI::CardComponent.new(title: "Data & Privacy", icon: icons[:download]) do %>
      <div class="space-y-4">
        <!-- Export -->
        <div class="flex items-center justify-between p-3 bg-muted/60 rounded-lg">
          <div>
            <h3 class="text-sm font-medium text-foreground">Export Your Data</h3>
            <p class="text-xs text-muted-foreground mt-0.5">Download a JSON file with your account info and items.</p>
          </div>
          <%= render UI::ButtonComponent.new(variant: :secondary, size: :sm, data: { action: "click->settings#exportData", "settings-target": "exportButton" }) do %>
            <span class="inline-flex items-center gap-1">
              <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Export
            </span>
          <% end %>
        </div>

        <!-- Delete Account -->
        <div class="flex items-center justify-between p-3 bg-destructive/10 rounded-lg border border-destructive/30">
          <div>
            <h3 class="text-sm font-medium text-destructive">Delete Account</h3>
            <p class="text-xs text-destructive/80 mt-0.5">Permanently remove your account and all data.</p>
          </div>
          <%= render UI::ButtonComponent.new(variant: :destructive, size: :sm, data: { action: "click->settings#showDeleteModal" }) do %>
            <span class="inline-flex items-center gap-1">
              <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
              Delete
            </span>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Delete confirmation modal -->
    <div data-settings-target="deleteModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50" role="dialog" aria-modal="true" aria-labelledby="delete-modal-title">
      <div class="bg-card text-card-foreground rounded-2xl shadow-xl border border-border w-full max-w-sm p-6">
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-5 h-5 text-destructive" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
          <h3 id="delete-modal-title" class="text-lg font-bold text-foreground">Delete Account</h3>
        </div>
        <p class="text-sm text-muted-foreground mb-1">This will permanently delete your account and all associated data. This action cannot be undone.</p>
        <p class="text-sm text-muted-foreground mb-4">Type <span class="font-mono font-semibold text-destructive">DELETE</span> to confirm.</p>
        <input type="text" data-settings-target="deleteConfirmInput" placeholder="Type DELETE" aria-label="Type DELETE to confirm" class="w-full border border-input bg-background text-foreground rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-destructive mb-4" />
        <div class="flex gap-3">
          <%= render UI::ButtonComponent.new(variant: :secondary, class: "flex-1", data: { action: "click->settings#hideDeleteModal" }) { "Cancel" } %>
          <%= render UI::ButtonComponent.new(variant: :destructive, class: "flex-1", data: { action: "click->settings#deleteAccount", "settings-target": "deleteButton" }) { "Delete Account" } %>
        </div>
      </div>
    </div>

    <div class="pb-8"></div>
  </main>
</div>
