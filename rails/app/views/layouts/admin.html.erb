<!DOCTYPE html>
<html lang="en" class="<%= cookies[:theme] == 'dark' ? 'dark' : '' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= content_for?(:title) ? "#{yield(:title)} — Admin — #{app_name}" : "Admin — #{app_name}" %></title>

  <script>
    (function() {
      var theme = localStorage.getItem('theme') || 'system';
      if (theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    })();
  </script>

  <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            background: 'var(--background)',
            foreground: 'var(--foreground)',
            card: { DEFAULT: 'var(--card)', foreground: 'var(--card-foreground)' },
            popover: { DEFAULT: 'var(--popover)', foreground: 'var(--popover-foreground)' },
            primary: { DEFAULT: 'var(--primary)', foreground: 'var(--primary-foreground)' },
            secondary: { DEFAULT: 'var(--secondary)', foreground: 'var(--secondary-foreground)' },
            muted: { DEFAULT: 'var(--muted)', foreground: 'var(--muted-foreground)' },
            accent: { DEFAULT: 'var(--accent)', foreground: 'var(--accent-foreground)' },
            destructive: { DEFAULT: 'var(--destructive)', foreground: 'var(--destructive-foreground)' },
            success: { DEFAULT: 'var(--success)', foreground: 'var(--success-foreground)' },
            warning: { DEFAULT: 'var(--warning)', foreground: 'var(--warning-foreground)' },
            info: { DEFAULT: 'var(--info)', foreground: 'var(--info-foreground)' },
            border: 'var(--border)',
            input: 'var(--input)',
            ring: 'var(--ring)',
          },
          borderRadius: {
            lg: 'var(--radius)',
            md: 'calc(var(--radius) - 2px)',
            sm: 'calc(var(--radius) - 4px)',
          },
        },
      },
    }
  </script>

  <!-- EasyMDE markdown editor -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css">
  <script src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>
  <style>
    /* Fix EasyMDE preview styling (Tailwind reset strips defaults) */
    .editor-preview h1, .editor-preview-side h1 { font-size: 2em; font-weight: 700; margin: 0.67em 0; }
    .editor-preview h2, .editor-preview-side h2 { font-size: 1.5em; font-weight: 700; margin: 0.83em 0; }
    .editor-preview h3, .editor-preview-side h3 { font-size: 1.25em; font-weight: 600; margin: 1em 0; }
    .editor-preview h4, .editor-preview-side h4 { font-size: 1.1em; font-weight: 600; margin: 1em 0; }
    .editor-preview ul, .editor-preview-side ul { list-style: disc; padding-left: 2em; margin: 1em 0; }
    .editor-preview ol, .editor-preview-side ol { list-style: decimal; padding-left: 2em; margin: 1em 0; }
    .editor-preview li, .editor-preview-side li { margin: 0.25em 0; }
    .editor-preview p, .editor-preview-side p { margin: 1em 0; }
    .editor-preview blockquote, .editor-preview-side blockquote { border-left: 4px solid #d1d5db; padding-left: 1em; margin: 1em 0; color: #6b7280; }
    .editor-preview code, .editor-preview-side code { background: #f3f4f6; padding: 0.2em 0.4em; border-radius: 4px; font-size: 0.875em; }
    .editor-preview pre, .editor-preview-side pre { background: #1f2937; color: #e5e7eb; padding: 1em; border-radius: 8px; overflow-x: auto; margin: 1em 0; }
    .editor-preview pre code, .editor-preview-side pre code { background: none; padding: 0; }
    .editor-preview a, .editor-preview-side a { color: #10b981; text-decoration: underline; }
    .editor-preview hr, .editor-preview-side hr { border: none; border-top: 1px solid #e5e7eb; margin: 2em 0; }
    .editor-preview table, .editor-preview-side table { border-collapse: collapse; width: 100%; margin: 1em 0; }
    .editor-preview th, .editor-preview-side th, .editor-preview td, .editor-preview-side td { border: 1px solid #d1d5db; padding: 0.5em 0.75em; text-align: left; }
    .editor-preview th, .editor-preview-side th { background: #f9fafb; font-weight: 600; }
    .editor-preview img, .editor-preview-side img { max-width: 100%; border-radius: 8px; }
    /* Dark mode */
    .dark .editor-preview, .dark .editor-preview-side { background: #18181b; color: #e4e4e7; }
    .dark .editor-preview code, .dark .editor-preview-side code { background: #27272a; }
    .dark .editor-preview blockquote, .dark .editor-preview-side blockquote { border-color: #3f3f46; color: #a1a1aa; }
    .dark .editor-preview th, .dark .editor-preview-side th { background: #27272a; }
    .dark .editor-preview td, .dark .editor-preview-side td, .dark .editor-preview th, .dark .editor-preview-side th { border-color: #3f3f46; }
    .dark .editor-preview hr, .dark .editor-preview-side hr { border-color: #3f3f46; }
    /* Dark mode editor chrome */
    .dark .EasyMDEContainer .CodeMirror { background: #18181b; color: #e4e4e7; border-color: #3f3f46; }
    .dark .EasyMDEContainer .editor-toolbar { border-color: #3f3f46; }
    .dark .EasyMDEContainer .editor-toolbar button { color: #a1a1aa !important; }
    .dark .EasyMDEContainer .editor-toolbar button:hover { background: #27272a; }
    .dark .EasyMDEContainer .editor-statusbar { color: #71717a; }
    .dark .EasyMDEContainer .CodeMirror-cursor { border-color: #e4e4e7; }
    .dark .editor-preview-side { border-color: #3f3f46; }
  </style>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-background text-foreground min-h-screen">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-56 shrink-0 border-r border-border bg-card flex flex-col">
      <div class="p-4 border-b border-border">
        <h1 class="text-lg font-bold text-foreground">Admin</h1>
      </div>

      <nav class="flex-1 p-3 space-y-1">
        <%
          admin_nav = [
            { href: "/admin", label: "Dashboard", icon: "layout", exact: true },
            { href: "/admin/users", label: "Users", icon: "users" },
            { href: "/admin/database", label: "Database", icon: "database" },
            { href: "/admin/analytics", label: "Analytics", icon: "chart" },
            { href: "/admin/roles", label: "Roles", icon: "shield" },
            { href: "/admin/waitlist", label: "Waitlist", icon: "clock" },
            { href: "/admin/crm", label: "CRM", icon: "mail" },
            { href: "/admin/logs", label: "Audit Logs", icon: "scroll" },
          ]
        %>
        <% admin_nav.each do |item| %>
          <%
            is_active = item[:exact] ? request.path == item[:href] : request.path.start_with?(item[:href])
            active_css = is_active ? "bg-accent text-accent-foreground" : "text-muted-foreground hover:text-foreground hover:bg-muted"
          %>
          <a href="<%= item[:href] %>" class="flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium transition-colors <%= active_css %>">
            <% case item[:icon] %>
            <% when "layout" %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
            <% when "users" %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            <% when "database" %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            <% when "chart" %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            <% when "mail" %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <% when "shield" %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <% when "clock" %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <% when "scroll" %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 21h12a2 2 0 002-2v-2H10v2a2 2 0 11-4 0V5a2 2 0 00-2-2H2"/><path d="M19 3H8a2 2 0 00-2 2v14"/></svg>
            <% end %>
            <%= item[:label] %>
          </a>
        <% end %>
      </nav>

      <div class="p-3 border-t border-border">
        <a href="/app" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm text-muted-foreground hover:text-foreground transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back to App
        </a>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 p-6 lg:p-8 overflow-auto">
      <% if flash[:notice] %>
        <div class="mb-4" data-controller="toast" data-toast-type-value="success" data-toast-timeout-value="5000">
          <%= render UI::AlertComponent.new(variant: :success) { flash[:notice] } %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mb-4" data-controller="toast" data-toast-type-value="error" data-toast-timeout-value="5000">
          <%= render UI::AlertComponent.new(variant: :error) { flash[:alert] } %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </div>
</body>
</html>
