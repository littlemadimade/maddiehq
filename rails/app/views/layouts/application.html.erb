<!DOCTYPE html>
<html lang="en" class="<%= cookies['maddiehq-theme'] == 'dark' ? 'dark' : '' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= content_for?(:title) ? "#{yield(:title)} — #{app_name}" : app_name %></title>
  <meta name="description" content="<%= content_for?(:description) ? yield(:description) : "#{app_name} — Ship your next idea faster" %>" />
  <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : app_name %>" />
  <meta property="og:description" content="<%= content_for?(:description) ? yield(:description) : "#{app_name} — Ship your next idea faster" %>" />
  <meta property="og:image" content="<%= "#{app_url}/og-image.svg" %>" />
  <meta property="og:type" content="website" />
  <%= yield(:head) if content_for?(:head) %>

  <!-- Anti-FOUC: set dark mode before paint -->
  <script>
    (function() {
      function getCookie(name) {
        var m = document.cookie.match('(?:^|; )' + name + '=([^;]*)');
        return m ? m[1] : null;
      }
      var theme = localStorage.getItem('theme') || getCookie('maddiehq-theme') || 'system';
      if (theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    })();
  </script>

  <!-- Tailwind Play CDN generates utility classes at runtime.
       The compiled tailwind.css (via stylesheet_link_tag) provides
       the :root / .dark token variable definitions. Both are needed
       until the tailwindcss-rails gem's CLI supports aarch64-linux
       for proper ahead-of-time compilation with @theme inline. -->
  <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            background: 'var(--background)',
            foreground: 'var(--foreground)',
            card: { DEFAULT: 'var(--card)', foreground: 'var(--card-foreground)' },
            popover: { DEFAULT: 'var(--popover)', foreground: 'var(--popover-foreground)' },
            primary: { DEFAULT: 'var(--primary)', foreground: 'var(--primary-foreground)' },
            secondary: { DEFAULT: 'var(--secondary)', foreground: 'var(--secondary-foreground)' },
            muted: { DEFAULT: 'var(--muted)', foreground: 'var(--muted-foreground)' },
            accent: { DEFAULT: 'var(--accent)', foreground: 'var(--accent-foreground)' },
            destructive: { DEFAULT: 'var(--destructive)', foreground: 'var(--destructive-foreground)' },
            success: { DEFAULT: 'var(--success)', foreground: 'var(--success-foreground)' },
            warning: { DEFAULT: 'var(--warning)', foreground: 'var(--warning-foreground)' },
            info: { DEFAULT: 'var(--info)', foreground: 'var(--info-foreground)' },
            border: 'var(--border)',
            input: 'var(--input)',
            ring: 'var(--ring)',
          },
          borderRadius: {
            lg: 'var(--radius)',
            md: 'calc(var(--radius) - 2px)',
            sm: 'calc(var(--radius) - 4px)',
          },
        },
      },
    }
  </script>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-background text-foreground min-h-screen">
  <% if flash[:notice] %>
    <div class="hidden" data-controller="toast" data-toast-type-value="success" data-toast-timeout-value="5000"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="hidden" data-controller="toast" data-toast-type-value="error" data-toast-timeout-value="5000"><%= flash[:alert] %></div>
  <% end %>

  <%= yield %>

  <!-- Command palette -->
  <%= render "shared/command_palette" %>

  <!-- Cookie consent -->
  <div id="cookie-consent" class="hidden fixed bottom-0 inset-x-0 z-50 p-4 bg-card text-card-foreground border-t border-border shadow-lg" data-controller="cookie-consent" role="region" aria-label="Cookie consent">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-muted-foreground">We use cookies to improve your experience. By continuing, you agree to our cookie policy.</p>
      <div class="flex gap-2">
        <%= render UI::ButtonComponent.new(variant: :secondary, size: :sm, data: { action: "click->cookie-consent#acceptEssential" }) { "Essential Only" } %>
        <%= render UI::ButtonComponent.new(variant: :primary, size: :sm, data: { action: "click->cookie-consent#acceptAll" }) { "Accept All" } %>
      </div>
    </div>
  </div>
</body>
</html>
