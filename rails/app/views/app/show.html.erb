<% content_for(:title) { "Dashboard" } %>

<!-- Onboarding -->
<div data-controller="onboarding">
  <div data-onboarding-target="modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4" role="dialog" aria-modal="true" aria-labelledby="onboarding-step-title">
    <div class="bg-card text-card-foreground rounded-2xl shadow-xl max-w-md w-full p-6 border border-border">
      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-1.5" data-onboarding-target="progress" aria-label="Onboarding progress"></div>
        <button type="button" data-action="click->onboarding#skip" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Skip onboarding">
          <svg class="w-5 h-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Step content -->
      <div class="text-center mb-8">
        <div class="flex items-center justify-center w-16 h-16 bg-accent rounded-2xl mx-auto mb-4">
          <svg data-onboarding-target="iconSprout" class="w-8 h-8 text-primary" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2C12 2 8 6 8 10C8 12.21 9.79 14 12 14C14.21 14 16 12.21 16 10C16 6 12 2 12 2Z"/><path d="M12 14V22"/><path d="M8 18H16"/></svg>
          <svg data-onboarding-target="iconShield" class="hidden w-8 h-8 text-primary" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <svg data-onboarding-target="iconDatabase" class="hidden w-8 h-8 text-primary" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          <svg data-onboarding-target="iconZap" class="hidden w-8 h-8 text-primary" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h2 id="onboarding-step-title" class="text-xl font-bold text-foreground mb-2" data-onboarding-target="stepTitle"></h2>
        <p class="text-sm text-muted-foreground leading-relaxed" data-onboarding-target="stepDescription"></p>
        <p data-onboarding-target="planNote" class="hidden text-xs text-primary mt-3 font-medium">You're on the free plan. Upgrade anytime for full access.</p>
      </div>

      <!-- Navigation -->
      <div class="flex gap-3">
        <%= render UI::ButtonComponent.new(variant: :secondary, class: "hidden flex-1", data: { "onboarding-target": "backButton", action: "click->onboarding#back" }) { "Back" } %>
        <%= render UI::ButtonComponent.new(variant: :primary, class: "flex-1", data: { action: "click->onboarding#next" }) do %>
          <span data-onboarding-target="nextLabel">Next</span>
        <% end %>
      </div>

      <button type="button" data-onboarding-target="skipButton" data-action="click->onboarding#skip" class="w-full mt-3 text-sm text-muted-foreground hover:text-foreground transition-colors">Skip tour</button>
    </div>
  </div>
</div>

<div class="min-h-screen bg-muted" data-controller="items">
  <!-- Header -->
  <header class="bg-card border-b border-border sticky top-0 z-10">
    <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <svg class="w-6 h-6 text-primary" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2C12 2 8 6 8 10C8 12.21 9.79 14 12 14C14.21 14 16 12.21 16 10C16 6 12 2 12 2Z"/><path d="M12 14V22"/><path d="M8 18H16"/></svg>
        <span class="font-bold text-foreground"><%= app_name %></span>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-xs text-muted-foreground hidden sm:block" data-items-target="userEmail">Loading...</span>
        <span data-items-target="proBadge" class="hidden inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-accent text-accent-foreground">
          <svg class="w-3 h-3 mr-1" aria-hidden="true" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Pro
        </span>
        <!-- Notification Bell -->
        <div class="relative" data-controller="notifications">
          <button type="button" data-action="click->notifications#toggle" class="relative text-muted-foreground hover:text-foreground transition-colors" aria-label="Notifications">
            <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
            <span data-notifications-target="badge" class="hidden absolute -top-1.5 -right-1.5 w-4 h-4 bg-destructive text-destructive-foreground text-[10px] font-bold rounded-full flex items-center justify-center">0</span>
          </button>
          <div data-notifications-target="dropdown" class="hidden absolute right-0 top-8 w-80 bg-popover text-popover-foreground rounded-xl shadow-xl border border-border z-50 overflow-hidden">
            <div class="px-4 py-3 border-b border-border flex items-center justify-between">
              <h3 class="text-sm font-semibold text-foreground">Notifications</h3>
              <button type="button" data-action="click->notifications#markAllRead" class="text-xs text-primary hover:underline">Mark all read</button>
            </div>
            <div data-notifications-target="list" class="max-h-80 overflow-y-auto">
              <p class="px-4 py-8 text-center text-sm text-muted-foreground">No notifications yet</p>
            </div>
          </div>
        </div>

        <button type="button" data-controller="theme" data-action="click->theme#toggle" class="p-1 text-muted-foreground hover:text-foreground transition-colors" aria-label="Toggle theme">
          <svg class="w-4 h-4 hidden dark:block" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="w-4 h-4 block dark:hidden" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
        </button>
        <a href="/settings" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Settings">
          <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        </a>
        <button type="button" data-action="click->items#logout" class="text-muted-foreground hover:text-destructive transition-colors" aria-label="Sign out">
          <svg class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-6 space-y-6">
    <!-- Upgrade banner for free users -->
    <div data-items-target="upgradeBanner" class="hidden">
      <%= render UI::AlertComponent.new(variant: :info, dismissible: false) do %>
        <div class="flex items-center justify-between gap-2">
          <span>You're on the free plan.
            <button type="button" data-action="click->items#upgrade" class="font-semibold underline hover:opacity-80">Upgrade to Pro &rarr;</button>
          </span>
          <button type="button" data-action="click->items#dismissBanner" class="opacity-60 hover:opacity-100 ml-2" aria-label="Dismiss">&times;</button>
        </div>
      <% end %>
    </div>

    <!-- Welcome -->
    <%= render UI::CardComponent.new do %>
      <h1 class="text-xl font-bold text-foreground mb-1">
        Welcome back<span data-items-target="welcomeName"></span>!
      </h1>
      <p class="text-sm text-muted-foreground">
        You're signed in and ready to build.
        <span data-items-target="proMessage" class="hidden text-primary font-medium">You have Pro access.</span>
        <button type="button" data-items-target="upgradeLink" data-action="click->items#upgrade" class="hidden text-primary font-medium hover:text-primary/90 underline">Upgrade to Pro</button>
      </p>
    <% end %>

    <!-- Pro-gated feature example -->
    <%= render UI::CardComponent.new(title: "Pro Feature Example") do %>
      <div class="flex justify-end -mt-2 mb-4">
        <%= render UI::BadgeComponent.new(variant: :default, data: { "items-target": "proOnlyBadge" }) do %>
          <svg class="w-3 h-3 mr-1" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          Pro only
        <% end %>
      </div>
      <!-- Shown for Pro users -->
      <div data-items-target="proContent" class="hidden bg-accent text-accent-foreground rounded-xl p-4 text-center">
        <p class="font-medium text-sm">This is your Pro feature. Replace this with your actual Pro content.</p>
      </div>
      <!-- Shown for free users -->
      <div data-items-target="freeContent" class="text-center py-8">
        <svg class="w-8 h-8 text-muted-foreground mx-auto mb-3" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        <p class="text-sm text-muted-foreground mb-4">This feature requires a Pro subscription.</p>
        <%= render UI::ButtonComponent.new(variant: :primary, data: { action: "click->items#upgrade" }) do %>
          <span class="inline-flex items-center gap-2">
            <svg class="w-4 h-4" aria-hidden="true" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Upgrade to Pro
          </span>
        <% end %>
      </div>
    <% end %>

    <!-- Dashboard placeholder -->
    <%= render UI::CardComponent.new(title: "Dashboard Content") do %>
      <div class="bg-muted rounded-xl p-12 text-center border border-dashed border-border">
        <svg class="w-8 h-8 text-primary mx-auto mb-3" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2C12 2 8 6 8 10C8 12.21 9.79 14 12 14C14.21 14 16 12.21 16 10C16 6 12 2 12 2Z"/><path d="M12 14V22"/><path d="M8 18H16"/></svg>
        <p class="text-muted-foreground font-medium text-sm">Your app goes here.</p>
        <p class="text-muted-foreground/70 text-xs mt-1">Replace this placeholder with your actual UI. Auth, DB, Stripe, and email are all wired up.</p>
      </div>
    <% end %>

    <div class="pb-8"></div>
  </main>
</div>
