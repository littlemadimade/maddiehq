BETTER_AUTH_SECRET=change-me-run-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3005
DATABASE_PATH=./data/maddiehq.db

# PostgreSQL — set DATABASE_URL to use PG instead of SQLite.
# When set, DATABASE_PATH is ignored.
# DATABASE_URL=postgres://user:password@localhost:5432/maddiehq

# App base URL (used in emails, Stripe redirects, etc.)
# APP_URL=https://yourapp.example.com

# App display name (used in emails, MFA enrollment)
# APP_NAME=MaddieHQ

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (https://github.com/settings/developers)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# OAuth — Apple (https://developer.apple.com/account/resources/identifiers/list/serviceId)
# APPLE_CLIENT_ID is your Services ID (e.g. com.example.app.service), NOT your App Bundle ID.
# APPLE_CLIENT_SECRET is a short-lived JWT you must generate from your private key:
#   1. Create a "Sign In with Apple" key at https://developer.apple.com/account/resources/authkeys/list
#   2. Download the .p8 private key file (Team ID + Key ID shown there)
#   3. Generate the JWT: https://www.better-auth.com/docs/authentication/social-providers/apple
#      or use: npx @better-auth/cli generate-apple-secret
# The generated JWT expires after 6 months — regenerate and redeploy before expiry.
# APPLE_CLIENT_ID=com.example.app.service
# APPLE_CLIENT_SECRET=eyJ...

# OAuth — Facebook / Meta (https://developers.facebook.com/apps/)
# Create an app → Add "Facebook Login" product → Settings → Basic for ID/Secret.
# In production: add your domain to "Valid OAuth Redirect URIs" and supply a Privacy Policy URL.
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# OAuth — Microsoft (https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade)
# Register an app → Authentication → add redirect URI: {BETTER_AUTH_URL}/api/auth/callback/microsoft
# MICROSOFT_TENANT_ID defaults to "common" (personal + work/school accounts).
# Set to your specific tenant GUID for single-tenant / enterprise-only deployments.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# Email — Resend (https://resend.com)
# RESEND_API_KEY=re_...
# EMAIL_FROM=AppSeed <hello@yourdomain.com>
# RESEND_AUDIENCE_ID=aud_...                       # Resend Audience ID for broadcast campaigns

# Marketing automation — Loops.so drip engine (optional, activates when set)
# LOOPS_API_KEY=loops_...

# Resend webhook secret for email analytics (opens, clicks, bounces)
# RESEND_WEBHOOK_SECRET=whsec_...

# Stripe (https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PRICE_ID=price_...                    # recurring subscription price
# STRIPE_LIFETIME_PRICE_ID=price_...           # one-time lifetime deal price
# STRIPE_WEBHOOK_SECRET=whsec_...

# Waitlist mode — set to "true" to gate signups behind invite codes
# WAITLIST_MODE=true
# NEXT_PUBLIC_WAITLIST_MODE=true

# Analytics — pluggable event tracking (posthog, plausible, console, none)
# ANALYTICS_PROVIDER=posthog
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://app.posthog.com
# PLAUSIBLE_DOMAIN=yourapp.com
# PLAUSIBLE_HOST=https://plausible.io

# AI Chatbot — Anthropic Claude (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...
# CHAT_MODEL=claude-sonnet-4-20250514        # optional, defaults to Sonnet 4
# CHAT_MAX_TOKENS=1024                         # optional, max tokens per response

# Voice — ElevenLabs TTS (https://elevenlabs.io — optional, text-only if unset)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9   # optional, default voice

# Error monitoring — Sentry (https://sentry.io — free tier: 5K errors/month)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_...   # optional, for source map upload

# Admin — comma-separated list of emails to bootstrap as admins on startup
ADMIN_EMAILS=admin@example.com
